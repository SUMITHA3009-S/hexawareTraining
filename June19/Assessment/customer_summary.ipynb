   "source": [
    "customer_df = spark.table(\"customer_table\")\n",
    "\n",
    "customer_df.createOrReplaceTempView(\"customer_table\")\n",
    "\n",
    "summary_df = spark.sql(\"\"\"\n",
    "SELECT city,\n",
    "       COUNT(*) AS customer_count\n",
    "FROM customer_table\n",
    "GROUP BY city\n",
    "\"\"\")\n",
    "\n",
    "display(summary_df)\n",
    "\n",
    "print(\"Customer Summary Completed\")"
   ]
